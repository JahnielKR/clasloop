# ─── Clasloop Environment Variables ───
# Copy this file to .env and fill in your values.
# Vercel: set these in Project Settings → Environment Variables.
# DO NOT commit a populated .env (gitignored).
# DO NOT paste real production keys here — keep this as a placeholder template.

# ── Supabase ──
# Get from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Sentry (optional) — error tracking en producción (PR 67) ──
# Crear cuenta en sentry.io → New Project → React → copiar la DSN.
# Si esta var NO está seteada, la app funciona idéntico pero sin error tracking.
# Solo se inicializa en production builds (no en `npm run dev`).
VITE_SENTRY_DSN=https://YOUR_KEY@oXXXXX.ingest.us.sentry.io/YYYYY

# ── PostHog (optional) — analytics / event tracking (PR 69) ──
# Crear cuenta en posthog.com → New Project → JavaScript → copiar la project API key.
# Si esta var NO está seteada, la app funciona idéntico pero sin tracking.
# Solo se inicializa en production builds (no en `npm run dev`).
VITE_POSTHOG_KEY=phc_YOUR_POSTHOG_KEY

# Opcional: host de PostHog. Default = us.i.posthog.com.
# Si tu organización está en EU, usar https://eu.i.posthog.com.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── Backend-only (set in Vercel, NOT in client .env) ───
# Estas NO llevan prefijo VITE_ — son leídas por las funciones serverless
# en api/ y por la Edge Function de Supabase. Nunca deben llegar al bundle
# del cliente. Documentadas aquí para referencia:
#
#   ANTHROPIC_API_KEY           Claude API key (api/generate.js, api/*.js)
#   SUPABASE_URL                Same value as VITE_SUPABASE_URL above (server-side)
#   SUPABASE_SERVICE_KEY        Service role key from Supabase Settings → API
#   SUPABASE_SERVICE_ROLE_KEY   Idem (some endpoints use this name)
#   WEBHOOK_SECRET              Random string. See PR 90 for Edge Function auth.
