.env
.env.local
.env*.local
node_modules/
dist/
.DS_Store

# Capacitor: el directorio android/ se commitea (contiene configuración
# importante como AndroidManifest.xml, build.gradle, etc). Capacitor mismo
# genera un .gitignore adecuado adentro de android/ cuando se hace
# `npx cap add android`, que excluye los outputs de build.
#
# Lo único que ignoramos a nivel raíz son los iOS Pods (si en el futuro
# agregamos iOS), porque pueden ser pesados y se regeneran con `pod install`.
ios/App/Pods/
ios/App/build/

.vercel
.env*

# Playwright e2e (PR 167) — generated artifacts, never committed
/test-results/
/playwright-report/
/playwright/.cache/

# Claude Code / local agent tooling — kept out of the repo. All local and
# regenerated: agent worktrees, personal skills, preview launch config, the
# Playwright MCP snapshots, and the Supabase CLI temp dir.
.claude/
.playwright-mcp/
.superpowers/
supabase/.temp/

# AI-session planning / audit docs — generated during agent sessions, kept
# local rather than tracked as project source. Use `git add -f` to commit one
# deliberately.
/ANALYSIS.md
/ANALYSIS_vs_HANDOFF.md
/AUDITORIA.md
/PRs/
