# Copy this file to android/keystore.properties and fill in real values.
# android/keystore.properties is gitignored — it holds your signing secrets.
#
# Create the upload keystore once (see docs/ANDROID_RELEASE_RUNBOOK.md):
#   keytool -genkey -v -keystore clasloop-upload.jks -alias clasloop \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ directory.

storeFile=clasloop-upload.jks
storePassword=CHANGE_ME
keyAlias=clasloop
keyPassword=CHANGE_ME
